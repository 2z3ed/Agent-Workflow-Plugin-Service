APP_NAME=agent-workflow-plugin-service
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ==================== 数据库 ====================
DATABASE_PATH=./data/tasks.db

# ==================== 邮箱配置（必填） ====================
# 格式：邮箱:授权码:imap服务器，多个用分号分隔
# 示例：user1@163.com:ABCDEFGHIJKLMNOP:imap.163.com;user2@126.com:1234567890:imap.126.com
MAILBOXES=your_email@163.com:your_authorization_code:imap.163.com

# 每个邮箱最多读取的邮件数
MAX_EMAILS_PER_BOX=20

# 查询最近多少天内的邮件
LOOKBACK_DAYS=1

# 是否只读取未读邮件
ONLY_UNREAD=true

# ==================== Dify 配置（按插件独立，必填） ====================
# 邮件插件工作流
EMAIL_DIFY_API_URL=http://localhost/v1/workflows/run
EMAIL_DIFY_API_KEY=app-email-workflow-key

# 选品插件工作流
PRODUCT_DIFY_API_URL=http://localhost/v1/workflows/run
PRODUCT_DIFY_API_KEY=app-product-workflow-key

# Listing 优化插件工作流（listing_optimizer，无全局回退）
LISTING_DIFY_API_URL=http://localhost/v1/workflows/run
LISTING_DIFY_API_KEY=app-listing-workflow-key

# ==================== 飞书长连接配置（必填） ====================
# 企业自建应用的 App ID 和 App Secret（从飞书开放平台获取）
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# 是否启用长连接（固定 true）
FEISHU_ENABLE_LONG_CONN=true

# 如果你没有 Webhook，这两项留空即可（长连接模式不需要）
FEISHU_WEBHOOK_URL=
FEISHU_SECRET=

# 目标接收者的 ID（群聊 chat_id 或用户 open_id）
# 如何获取 chat_id：将机器人加入群聊后，通过飞书开放平台的“调试台”或监听事件获取
FEISHU_CHAT_ID=oc_xxxxxxxxxxxx

# 发送方式：chat 或 user
FEISHU_RECEIVER_TYPE=chat

# 是否发送飞书消息（邮件报告）
SEND_FEISHU=true

# ==================== 报警配置 ====================
# 报警频率限制（分钟），0 表示不限
ALERT_FREQUENCY_LIMIT_MINUTES=10